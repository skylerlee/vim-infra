Execute (Test json encoding):
  let g:data = { 'a': 'foo', 'b': 'bar' }
  let g:json = infra#json#encode(g:data)
  AssertEqual '{"a":"foo","b":"bar"}', g:json

Execute (Test json decoding):
  let g:json = '{ "a": "foo", "b": "bar" }'
  let g:data = infra#json#decode(g:json)
  AssertEqual 'foo', g:data.a
  AssertEqual 'bar', g:data.b
