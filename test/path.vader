Execute (Test path joining):
  AssertEqual 'a/b', infra#path_join('a', 'b')
  AssertEqual 'a/b/c', infra#path_join('a', 'b', 'c')
  AssertEqual 'a/b/c', infra#path_join('a/', '/b/', 'c/')
  AssertEqual '/a/b/c', infra#path_join('/a/', '/b', '/c/')
  AssertEqual '/a/b/c', infra#path_join('/', 'a/b', 'c/')
  AssertEqual '/a/b//c', infra#path_join('/a', '/b//c/')
